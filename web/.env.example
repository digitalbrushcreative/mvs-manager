# API origin (no trailing slash). Leave blank in dev — Vite proxies /api → :3001.
# In prod, set to the deployed API URL, e.g.:
#   VITE_API_URL=https://mvs-api.up.railway.app
VITE_API_URL=

# Google Drive integration (documents).
# Without these, DocumentForm falls back to filename-only mode.
#
# 1. Google Cloud Console → APIs & Services → Library → enable "Google Drive API"
# 2. Credentials → Create Credentials → OAuth client ID → Web application
#    Authorized JavaScript origins:
#      http://localhost:5173
#      <your production origin>
# 3. Paste the client ID below and copy this file to .env.local
VITE_GOOGLE_CLIENT_ID=

# Optional: a folder ID under which all per-trip folders are created.
# Default 'root' uses the user's My Drive root.
# VITE_GDRIVE_ROOT_FOLDER_ID=
